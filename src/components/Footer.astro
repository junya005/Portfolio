---
// src/components/Footer.astro
const today = new Date();
const socialLinks = [{ name: "GitHub", url: "https://github.com/junya005" }];
---

<footer class="footer">
  <div class="container">
    <p>&copy; {today.getFullYear()} Junya Kobayashi. All rights reserved.</p>
    <nav class="social-links">
      {
        socialLinks.map((link) => (
          <a href={link.url} target="_blank" rel="noopener noreferrer">
            {link.name}
          </a>
        ))
      }
    </nav>
  </div>
</footer>

<style>
  .footer {
    background-color: #52c3f1;
    color: #fff;
    padding: 2rem 1rem;
    text-align: center;
    border-top: 1px solid #eee;
    margin-top: auto; /* レイアウトの最下部に固定する場合 */
  }
  .container {
    max-width: 800px;
    margin: 0 auto;
  }
  .social-links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1rem;
  }
  .social-links a {
    color: #fff;
    text-decoration: none;
    transition: color 0.2s;
  }
  .social-links a:hover {
    color: #8592a3;
  }
</style>
