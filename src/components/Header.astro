---
import { Icon } from "astro-icon/components";

const baseUrl = import.meta.env.BASE_URL;
---

<header class="site-header">
  <div class="container">
    <a href={`${baseUrl}/`} class="logo">
      <Icon name="junya005" class="logo-icon" />
    </a>
    <nav class="nav">
      <ul>
        <li><a href={`${baseUrl}/`}>ホーム</a></li>
        <li><a href={`${baseUrl}/game/`}>ゲーム</a></li>
        <li><a href={`${baseUrl}/sound/`}>サウンド</a></li>
        <li><a href={`${baseUrl}/illustration/`}>イラスト</a></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background-color: #52c3f1;
    color: #fff;
    padding: 1rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .container {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 1rem;
  }

  /* リンクによる色変更の阻止 */
  .logo,
  .logo:visited,
  .logo:active,
  .logo:focus {
    width: 180px;
    text-decoration: none;
    color: inherit;
    outline: none;
    display: inline-block;
  }
  .logo-icon {
    color: #fff;
    width: 100%;
    height: auto;
    display: block;
  }
  .nav ul {
    list-style: none;
    display: flex;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
  }
  .nav a {
    text-decoration: none;
    color: #eee;
    font-weight: 500;
    font-size: 1.2rem;
    transition: color 0.2s;
  }
  .nav a:hover {
    color: #fff;
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .container {
      flex-direction: column;
      gap: 1rem;
    }
    .nav ul {
      gap: 1rem;
    }
  }
</style>
