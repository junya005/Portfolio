---
// プロフィールデータの定義（Propsとして受け取ることも可能）
const profile = {
  name: "小林 純也",
  role: "Game Developer",
  avatar: "/portfolio/images/icons/avater.jpg",
  bio: "現在専門学校でゲーム開発を学んでいる学生です。主にフロントエンドの開発を行っています。",
};
---

<div class="profile-container">
  <!-- 左カラム: アイコンと名前情報 -->
  <aside class="sidebar">
    <img src={profile.avatar} alt={profile.name} class="avatar" />
    <div class="info">
      <h1>{profile.name}</h1>
      <p class="role">{profile.role}</p>
    </div>
  </aside>

  <!-- 右カラム: 略歴など -->
  <main class="content">
    <section>
      <h2>About Me</h2>
      <p>{profile.bio}</p>
    </section>
  </main>
</div>

<style>
  .profile-container {
    display: grid;
    grid-template-columns: 200px 1fr; /* 左を固定、右を可変に */
    gap: 2rem;
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
  }

  .sidebar {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .avatar {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 1rem;
    background-color: #8592a3;
  }

  .info h1 {
    font-size: 1.5rem;
    margin: 0;
  }

  .info .role {
    color: #8592a3;
    margin-top: 0.25rem;
  }

  .content h2 {
    border-bottom: 2px solid #8592a3;
    padding-bottom: 0.5rem;
    margin-bottom: 1rem;
  }

  /* レスポンシブ対応：スマホでは縦並びにする */
  @media (max-width: 600px) {
    .profile-container {
      grid-template-columns: 1fr;
    }
    .sidebar {
      align-items: center;
      text-align: center;
    }
  }
</style>
