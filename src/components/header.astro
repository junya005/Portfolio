---
// astro.config.mjs の base 設定を取得
const baseUrl = import.meta.env.BASE_URL; 
---

<header class="site-header">
  <div class="container">
    <a href={`${baseUrl}/`} class="logo">My Portfolio</a>
    <nav class="nav">
      <ul>
        <li><a href={`${baseUrl}/game`}>ゲーム</a></li>
        <li><a href={`${baseUrl}/sound`}>サウンド</a></li>
        <li><a href={`${baseUrl}/illustration`}>イラスト</a></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background-color: #333;
    color: #fff;
    padding: 1rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .container {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 1rem;
  }
  .logo {
    font-size: 1.5rem;
    font-weight: bold;
    text-decoration: none;
    color: #fff;
  }
  .nav ul {
    list-style: none;
    display: flex;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
  }
  .nav a {
    text-decoration: none;
    color: #eee;
    font-weight: 500;
    transition: color 0.2s;
  }
  .nav a:hover {
    color: #fff;
    text-decoration: underline;
  }

  /* スマホ対応 */
  @media (max-width: 600px) {
    .container {
      flex-direction: column;
      gap: 1rem;
    }
    .nav ul {
      gap: 1rem;
    }
  }
</style>
