---
import Header from '../components/Header.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    <!-- ここでヘッダーを呼び出す -->
    <Header />
    <slot /> <!-- ここに各ページの内容が入る -->
  </body>
</html>

<style is:global>
  body {
    margin: 0;
    font-family: sans-serif;
    background-color: #f9f9f9;
  }
</style>
