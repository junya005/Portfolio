---
// src/pages/portfolio/[category]/[id].astro
import { getEntry } from 'astro:content';
import worksData from '../../../data/projects.json';

export async function getStaticPaths() {
  return worksData.map(work => ({
    params: { category: work.category, id: work.id },
    props: { work }
  }));
}

const { work } = Astro.props;

// JSONの contentId を使って Markdownを取得
const entry = await getEntry('posts', work.detailPath);
const { Content } = await entry.render();
---

<html>
  <body>
    <h1>{work.title}</h1> <!-- JSONのデータ -->
    <div class="content">
      <Content /> <!-- Markdownの中身 -->
    </div>
  </body>
</html>
