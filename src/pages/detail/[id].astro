---
// src/pages/detail/[id].astro
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content"; // renderをインポート

export async function getStaticPaths() {
  const allPosts = await getCollection("posts");
  return allPosts.map((entry) => ({
    params: { id: entry.id }, // 最新版では slug ではなく id を使うのが一般的です
    props: { entry },
  }));
}

const { entry } = Astro.props;

// 旧: const { Content } = await entry.render();
// 新: render(entry) を使用します
const { Content } = await render(entry);
---

<Layout title={entry.data.title}>
  <main>
    <div class="markdown-body">
      <h1>{entry.data.title}</h1>
      <Content />
    </div>
  </main>
</Layout>

<style>
  main {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem;
  }
</style>
